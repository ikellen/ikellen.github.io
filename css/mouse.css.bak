/*页脚部分*/
#footer {
    background: transparent!important;
    color: #000;
    border-top-right-radius: 20px;
    border-top-left-radius: 20px;
    backdrop-filter: saturate(100%) blur(5px)
}
/*全局背景透明渐变*/
[data-theme='light'] #recent-posts>.recent-post-item,.layout_page>div:first-child:not(.recent-posts),.layout_post>#page,.layout_post>#post,.read-mode .layout_post>#post {
  /*background: var(--light_bg_color)*/
  background: #f0f6fc;
  padding: 2rem 3.75rem;
  border-radius: 1rem;
  box-shadow: 0 0.5rem 1rem rgb(54 100 152 / 15%), inset 0 0 0 1px #fff;
}
[data-theme='light'] #aside-content .card-widget {
  /*background: var(--light_bg_color)*/
  background: #f0f6fc;
  border-radius: 1rem;
  box-shadow: 0 0.5rem 1rem rgb(54 100 152 / 15%), inset 0 0 0 1px #fff;
}
[data-theme='light'] #post {
  background: #f0f6fc;
  border-radius: 1rem;
  box-shadow: 0 0.5rem 1rem rgb(54 100 152 / 15%), inset 0 0 0 1px #fff;

}
/**/
#footer::before {
    background: transparent!important
}

#footer #footer-wrap {
    color: #999AAA
}

#footer #footer-wrap a {
    color: #999AAA
}
#page h1.page-title, #post>#post-info {
  text-align: center;
}
/*twikoo页脚隐藏*/
.tk-footer {
  display: none;
}
.vpower {
  display: none;
}
/**/
[data-theme='dark'] #body-wrap:before, [data-theme='dark'] #footer:before, [data-theme='dark'] #page-header:before {
  background-color: rgba(0,0,0,0.7);
}
/*炫彩时间*
.logosvg {
  height:88px;
  width:240px;
  font-family:Source Serif Pro;
}
.words {
  font-size:50px;
  font-weight:bold;
  text-transform:uppercase;
  fill:none;
  stroke-width:1.5px;
  stroke-dasharray:90,310;
  animation-name:drawing;
  animation-duration:8s;
  animation-iteration-count:infinite;
  animation-timing-function:linear;
}
.words-1 {
  stroke:deepskyblue;
  text-shadow:0 0 30px #00bfff52;
  animation-delay:-2s;
}
.words-2 {
  stroke:lightseagreen;
  text-shadow:0 0 30px #20b2aa52;
  animation-delay:-4s;
}
.words-3 {
  stroke:orange;
  text-shadow:0 0 30px #ffa50052;
  animation-delay:-6s;
}
.words-4 {
  stroke:purple;
  text-shadow:0 0 30px #80008052;
  animation-delay:-8s;
}
@keyframes drawing {
  100% {
  stroke-dashoffset:-400;
}
}
*/
/*  */
/* 右侧小按钮圆角 */
#rightside>div>button,#to_comment {
  margin-right: 4px;
  border-radius: 7px;
  
}
#recent-posts > .recent-post-item .post_cover {
  margin-right: 2px;
  border-radius: 7px;
}
/*侧边滑动颜色*/
:root {
  --btn-bg: #5a6f87;
}
/*GitHub*/
#card-info-btn {
  border-radius: 7px;
  overflow: hidden;
}
#aside-content .aside-list > .aside-list-item .thumbnail {
  border-radius: 7px;
}
/* 博主昵称颜色 */
.author-info__name {
  color: #1d1d1f;
}
/*  */

::-webkit-scrollbar {
  width: 7px;
  height: 7px;
}

::-webkit-scrollbar-thumb {
  background-color: var(--btn-bg);
  background-image: -webkit-linear-gradient( 45deg, rgba(255, 255, 255, 0.4) 25%, transparent 25%, transparent 50%, rgba(255, 255, 255, 0.4) 50%, rgba(255, 255, 255, 0.4) 75%, transparent 75%, transparent);
  border-radius: 2em;
}

::-webkit-scrollbar-corner {
  background-color: transparent;
}

::-moz-selection {
  color: #fff;
  background-color: var(--btn-bg);
}
/**/
#aside-content #card-toc .toc-content .toc-link.active {
  border-radius: 7px;
  overflow: hidden;
  /*background: #00c4b6;
  color: #fff;*/
}